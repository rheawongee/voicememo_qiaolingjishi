<view class="bottom-nav">
  <view class="starburst-wrapper">
    <view class="starburst-container"></view>
  </view>
  <view class="nav-bar">
    <view class="nav-item {{value === 'home1' ? 'active' : ''}}" bindtap="onNavTap" data-value="home1">
      <t-icon name="home" size="48rpx" />
      <text>首页</text>
    </view>
    <view class="nav-item {{value === 'diary' ? 'active' : ''}}" bindtap="onNavTap" data-value="diary">
      <t-icon name="card" size="48rpx" />
      <text>已完成</text>
    </view>
    <view class="fab {{isRecording ? 'recording' : ''}}" bindtap="onRecordTap">
      <t-icon name="{{isRecording ? 'stop' : 'microphone'}}" size="80rpx" color="white" />
      <view class="rotate-ring"></view>
    </view>
    <view class="nav-item {{value === 'calendar' ? 'active' : ''}}" bindtap="onNavTap" data-value="calendar">
      <t-icon name="calendar" size="48rpx" />
      <text>日历</text>
    </view>
    <view class="nav-item {{value === 'my' ? 'active' : ''}}" bindtap="onNavTap" data-value="my">
      <t-icon name="user" size="48rpx" />
      <text>我的</text>
    </view>
  </view>
</view>

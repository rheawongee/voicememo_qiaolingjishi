<!--pages/home1/index.wxml-->
<view class="page-container">
  <!-- 头部背景 -->
  <view class="header-bg">
    <view class="halftone-bg"></view>
  </view>
  <!-- 撕裂纸张边缘 -->
  <view class="mask-torn-paper-top"></view>

  <!-- 自定义顶部栏 -->
  <view class="custom-header">
    <view class="menu-btn" bindtap="onMenuTap">
      <t-icon name="menu" size="40rpx" color="#1b1b1c" />
    </view>
    <view class="title">VoiceMemo</view>
    <view class="avatar-btn" bindtap="onAvatarTap">
      <image class="avatar-img" mode="aspectFill" src="/static/avatar1.png" />
    </view>
  </view>

  <view class="main-content">
    <!-- Hero 区域 -->
    <view class="hero-section">
      <view class="voice-circles">
        <view class="circle"></view>
        <view class="circle"></view>
        <view class="circle"></view>
      </view>
      <view class="agent-tag">
        <t-icon name="star" size="28rpx" color="white" />
        <text>Your AI Voice Agent</text>
      </view>
      <h2>Hey! I'm Bennett 👋</h2>
      <view class="sub">I can listen, summarize, and help you get things done.</view>
      <view class="character-area">
        <view class="bubble1 floating">LET'S TALK!</view>
        <view class="bubble2 floating">I'M ALL EARS! ❤️</view>
        <view class="deco-left"><t-icon name="sound" size="48rpx" /></view>
        <view class="deco-right"><t-icon name="chart-line" size="48rpx" color="white" /></view>
        <image class="hero-img" mode="aspectFit" src="https://lh3.googleusercontent.com/aida-public/AB6AXuAD4RhE7JPd6lua0po1T-u47dyZX2he8Ybk-M8FuCg643kveEU65qf9EBGssIhK-Dlp8MbT89byUoyrAtIs0-7EXOrXQoaRbvTWDNjEAyD29Yfw2QYFxGbWg10ANOEKkg42FulRK5k27Z-f0Woce4k0nAdhBeM97KagVByTi8AXF35iWDHSm0oNuua0_ZEoEN4INpvGN0c34JXWbiH31i3AWEGnqSPkVQgGUmZnr1Vh04KvT9EjfWTejFMZvzlmNKfL0gAGFn4m8kM" />
      </view>
    </view>

    <!-- 横向快速操作 -->
    <view class="quick-actions">
      <view class="section-header">Try asking me</view>
      <scroll-view scroll-x class="scroll-x" show-scrollbar="{{false}}">
        <view class="action-card" bindtap="onQuickAction" data-type="summarize">
          <view class="left">
            <view class="icon-bg"><t-icon name="microphone" size="40rpx" /></view>
            <view class="text">Summarize<br/>my meetings</view>
          </view>
          <view class="arrow"><t-icon name="chevron-right" size="36rpx" /></view>
        </view>
        <view class="action-card card2" bindtap="onQuickAction" data-type="email">
          <view class="left">
            <view class="icon-bg"><t-icon name="file-copy" size="40rpx" /></view>
            <view class="text">Draft a follow-up<br/>email</view>
          </view>
          <view class="arrow"><t-icon name="chevron-right" size="36rpx" /></view>
        </view>
        <view class="action-card card3" bindtap="onQuickAction" data-type="brainstorm">
          <view class="left">
            <view class="icon-bg"><t-icon name="lightbulb" size="40rpx" /></view>
            <view class="text">Brainstorm<br/>ideas</view>
          </view>
          <view class="arrow"><t-icon name="chevron-right" size="36rpx" /></view>
        </view>
      </scroll-view>
    </view>

    <!-- Recent 列表 -->
    <view class="recent-section">
      <view class="header-row">
        <h3>Recent</h3>
        <view class="view-all" bindtap="onViewAll">View all <t-icon name="chevron-right" size="32rpx" /></view>
      </view>
      <block wx:for="{{recentList}}" wx:key="id">
        <view class="record-item">
          <view class="item-icon {{item.iconColor === 'bg-pink' ? 'bg-pink' : 'bg-cyan'}}" style="background: {{item.iconColor === 'bg-pink' ? '#FF1493' : '#13D4E8'}}">
            <t-icon name="microphone" size="48rpx" color="white" />
          </view>
          <view class="info">
            <view class="title">{{item.title}}</view>
            <view class="meta">
              <text>{{item.date}}</text>
              <text>•</text>
              <text>{{item.time}}</text>
              <text>•</text>
              <text class="status">{{item.summaryStatus ? 'Summary ready' : 'New'}}</text>
            </view>
          </view>
          <view class="play-btn" bindtap="onPlayAudio" data-path="{{item.audioPath}}" data-id="{{item.id}}">
            <t-icon name="play-circle" size="40rpx" />
          </view>
          <view class="more"><t-icon name="more" size="40rpx" /></view>
        </view>
      </block>
    </view>

    <!-- 底部导航栏 + FAB -->
    <view class="bottom-nav">
      <view class="starburst-wrapper">
        <view class="starburst-container"></view>
      </view>
      <view class="nav-bar">
        <view class="nav-item active" bindtap="onNavTap" data-page="home">
          <t-icon name="home" size="48rpx" />
          <text>Home</text>
        </view>
        <view class="nav-item" bindtap="onNavTap" data-page="history">
          <t-icon name="time" size="48rpx" />
          <text>History</text>
        </view>
        <view class="fab {{isRecording ? 'recording' : ''}}" bindtap="onRecordTap">
          <t-icon name="{{isRecording ? 'stop' : 'microphone'}}" size="80rpx" color="white" />
          <view class="rotate-ring"></view>
        </view>
        <view class="nav-item" bindtap="onNavTap" data-page="saved">
          <t-icon name="bookmark" size="48rpx" />
          <text>Saved</text>
        </view>
        <view class="nav-item" bindtap="onNavTap" data-page="agents">
          <t-icon name="star" size="48rpx" />
          <text>Agents</text>
        </view>
      </view>
    </view>
  </view>
</view>
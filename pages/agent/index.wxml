<view class="agent-page">
  <view class="header-bg">
    <view class="halftone-bg"></view>
  </view>
  <view class="torn-paper-edge"></view>

  <view class="top-app-bar">
    <button class="circle-button menu-button" hover-class="button-hover">
      <text class="symbol">☰</text>
    </button>
    <view class="logo-wrap">
      <text class="logo-text">VoiceMemo</text>
    </view>
    <view class="profile-avatar">
      <image class="profile-image" mode="aspectFill" src="/static/avatar1.png" />
    </view>
  </view>

  <scroll-view class="main-scroll" scroll-y enhanced show-scrollbar="false">
    <view class="hero-section">
      <view class="voice-circles">
        <view class="voice-circle circle-1"></view>
        <view class="voice-circle circle-2"></view>
        <view class="voice-circle circle-3"></view>
      </view>

      <view class="hero-content">
        <view class="badge hard-shadow-sm">
          <text class="badge-icon">✦</text>
          <text>Your AI Voice Agent</text>
        </view>
        <text class="hero-title">Hey! I'm Bennett 👋</text>
        <text class="hero-desc">I can listen, summarize, and help you get things done.</text>

        <view class="character-stage">
          <view class="speech-bubble bubble-left hard-shadow-sm floating">
            <text>LET'S TALK!</text>
          </view>
          <view class="speech-bubble bubble-right hard-shadow-sm floating delay">
            <text>I'M ALL EARS! ❤️</text>
          </view>
          <view class="decor-card waves-card hard-shadow-sm">
            <text class="decor-symbol">≋</text>
          </view>
          <view class="decor-card eq-card hard-shadow-sm">
            <text class="decor-symbol white">▥</text>
          </view>
          <view class="hero-image-card">
            <image class="agent-character-image" mode="aspectFit" src="/static/image1.png" />
          </view>
        </view>
      </view>
    </view>

    <view class="quick-section">
      <view class="section-title-wrap">
        <text class="section-title">Try asking me</text>
      </view>
      <scroll-view class="action-scroll" scroll-x enhanced show-scrollbar="false">
        <view class="action-list">
          <button class="action-card action-cyan hard-shadow-md" hover-class="button-scale">
            <view class="action-left">
              <view class="action-icon translucent"><text>🎙</text></view>
              <text class="action-text dark">Summarize
my meetings</text>
            </view>
            <view class="action-arrow"><text>›</text></view>
          </button>
          <button class="action-card action-orange hard-shadow-md" hover-class="button-scale">
            <view class="action-left">
              <view class="action-icon translucent"><text>▤</text></view>
              <text class="action-text light">Draft a follow-up
email</text>
            </view>
            <view class="action-arrow"><text>›</text></view>
          </button>
          <button class="action-card action-pink-soft hard-shadow-md" hover-class="button-scale">
            <view class="action-left">
              <view class="action-icon translucent"><text>💡</text></view>
              <text class="action-text dark">Brainstorm
ideas</text>
            </view>
            <view class="action-arrow"><text>›</text></view>
          </button>
        </view>
      </scroll-view>
    </view>

    <view class="recent-section">
      <view class="recent-header">
        <text class="section-title">Recent</text>
        <button class="view-all" hover-class="none">View all <text class="chevron">›</text></button>
      </view>

      <view class="recent-list">
        <view wx:for="{{recentList}}" wx:key="title" class="recent-item hard-shadow-sm">
          <view class="recent-icon {{item.colorClass}}">
            <text>{{item.icon === 'mic' ? '🎙' : '▥'}}</text>
          </view>
          <view class="recent-info">
            <text class="recent-title">{{item.title}}</text>
            <view class="recent-meta">
              <text>{{item.date}}</text>
              <text>•</text>
              <text>{{item.duration}}</text>
              <text>•</text>
              <text class="ready">{{item.status}}</text>
            </view>
          </view>
          <button class="play-button {{item.colorClass}}-text" hover-class="none">▶</button>
          <button class="more-button" hover-class="none">⋮</button>
        </view>
      </view>
    </view>
  </scroll-view>

  <view class="bottom-nav">
    <view class="starburst-wrap">
      <view class="starburst"></view>
    </view>
    <view class="bottom-bar">
      <view class="nav-side">
        <button class="nav-button active" hover-class="none">
          <text class="nav-icon">⌂</text>
          <text class="nav-label">Home</text>
        </button>
        <button class="nav-button" hover-class="none">
          <text class="nav-icon">↺</text>
          <text class="nav-label">History</text>
        </button>
      </view>
      <view class="fab-wrap">
        <button class="record-fab {{isRecording ? 'recording' : ''}}" bindtap="toggleRecording" hover-class="none">
          <text class="fab-icon">{{isRecording ? '■' : '🎙'}}</text>
          <view class="fab-ring"></view>
        </button>
      </view>
      <view class="nav-side">
        <button class="nav-button" hover-class="none">
          <text class="nav-icon">▱</text>
          <text class="nav-label">Saved</text>
        </button>
        <button class="nav-button" hover-class="none">
          <text class="nav-icon">✦</text>
          <text class="nav-label">Agents</text>
        </button>
      </view>
    </view>
  </view>
</view>
